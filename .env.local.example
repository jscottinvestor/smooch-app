# Copy to .env.local and fill in. .env.local is gitignored and stays on your machine.

# Supabase — Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY-KEEP-SECRET

# Password gate — pick anything you'll remember. Used by proxy.ts to gate the app.
APP_PASSWORD=pick-a-password-here

# Anthropic API — for Phase 5 (receipt OCR). Leave blank until then.
ANTHROPIC_API_KEY=
